  "keyFeatures": [
    "70+ chart types including line, area, column, bar, pie, scatter, heatmap, and more",
    "Stock charts with advanced financial features and technical indicators",
    "Interactive maps with drill-down capabilities",
    "Gantt charts for project management and scheduling",
    "Real-time data updates and dynamic chart modifications",
    "Responsive design with mobile-friendly touch interactions",
    "Extensive customization through themes and styling options",
    "Accessibility features including keyboard navigation and screen reader support",
    "Export charts to PNG, JPG, SVG, and PDF formats",
    "Sonification for audio representation of chart data"
  ],
  "publicApiSurface": [
    "Highcharts.chart() - Create a chart",
    "Highcharts.stockChart() - Create a stock chart",
    "Highcharts.mapChart() - Create a map chart",
    "Highcharts.ganttChart() - Create a Gantt chart",
    "Chart.addSeries() - Add a series to a chart",
    "Chart.update() - Update chart configuration",
    "Series.addPoint() - Add a point to a series",
    "Series.setData() - Set series data",
    "Axis.setExtremes() - Set axis range",
    "Point.update() - Update point properties",
    "Chart.exportChart() - Export chart to image",
    "Highcharts.setOptions() - Set global options",
    "Highcharts.merge() - Merge configuration objects",
    "Highcharts.SVGRenderer - SVG rendering utilities",
    "Highcharts.dateFormat() - Format dates"
  ]
